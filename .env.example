# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_SERVICE_API_KEY: Your Resend/SendGrid/etc API key
EMAIL_SERVICE_API_KEY="your_api_key_here"

# BUSINESS_EMAIL_SENDER: The email address that notifications will be sent from
BUSINESS_EMAIL_SENDER="no-reply@dentacare.pro"

# SMTP email settings for booking confirmations
SMTP_HOST="mail.spacemail.com"
SMTP_PORT=465
SMTP_USER="me@aathilducky.com"
SMTP_PASS="shaniya.ducky123/A"
SMTP_FROM="me@aathilducky.com"

# SQLite database used by Prisma backend
DATABASE_URL="file:./dev.db"

# Admin authentication for Dashboard access
ADMIN_USERNAME="aathilducky"
ADMIN_PASSWORD="aathilducky"

# Session signing secret (32+ chars recommended)
SESSION_SECRET="replace_with_a_long_random_secret_key"
